{
  "name": "aurora-galactica",
  "version": "0.5.0-alpha.1",
  "description": "Classic fixed-screen browser shooter with keyboard controls, capture-and-rescue mechanics, multi-stage progression, and arcade-style tuning.",
  "main": "index.js",
  "scripts": {
    "build": "node tools/build/build-index.js",
    "build:production": "node tools/build/build-index.js --lane production",
    "promote:production": "node tools/build/promote-production.js",
    "publish:check:beta": "node tools/build/check-publish-ready.js --lane beta",
    "publish:check:production": "node tools/build/check-publish-ready.js --lane production",
    "publish:verify:beta": "node tools/build/verify-live-lane.js --lane beta",
    "publish:verify:production": "node tools/build/verify-live-lane.js --lane production",
    "publish:beta:raw": "node tools/build/publish-lane.js --lane beta",
    "publish:production:raw": "node tools/build/publish-lane.js --lane production",
    "publish:beta": "npm run build && npm run promote:beta && npm run publish:check:beta && npm run publish:beta:raw && npm run publish:verify:beta",
    "publish:production": "npm run build && npm run promote:production && npm run publish:check:production && npm run publish:production:raw && npm run publish:verify:production",
    "sync:public": "node tools/build/sync-public-pages.js",
    "verify:public": "node tools/build/verify-public-sync.js",
    "promote:beta": "node tools/build/promote-beta.js",
    "local:resume": "node tools/dev/local-resume.js",
    "local:stop": "node tools/dev/local-stop.js",
    "harness:analyze": "node tools/harness/analyze-run.js",
    "harness:batch": "node tools/harness/run-batch.js",
    "harness:check-latest": "node tools/harness/check-latest-run.js",
    "harness:import-latest": "node tools/harness/import-latest-run.js",
    "harness:tune": "node tools/harness/tuning-report.js",
    "harness:check:challenge-collision": "node tools/harness/check-challenge-collision.js",
    "harness:check:capture-escape": "node tools/harness/check-capture-escape.js",
    "harness:check:capture-shot-window": "node tools/harness/check-capture-shot-window.js",
    "harness:check:boss-first-hit": "node tools/harness/check-boss-first-hit-visual.js",
    "harness:check:carry-visuals": "node tools/harness/check-carry-visuals.js",
    "harness:check:capture-feedback": "node tools/harness/check-capture-feedback.js",
    "harness:check:capture-lifecycle": "node tools/harness/check-capture-lifecycle.js",
    "harness:check:squadron-spacing": "node tools/harness/check-squadron-spacing.js",
    "harness:check:stage-pressure": "node tools/harness/check-stage-pressure-balance.js",
    "harness:check:video-artifact": "node tools/harness/check-video-artifact.js",
    "harness:check:portable-paths": "node tools/harness/check-summary-portability.js",
    "harness:repair:videos": "node tools/harness/repair-video-artifacts.js",
    "harness:repair:summaries": "node tools/harness/sanitize-summary-paths.js",
    "harness:check:start-position": "node tools/harness/check-start-position.js",
    "harness:check:new-game-reset": "node tools/harness/check-new-game-reset.js",
    "harness:check:non-production-score-path": "node tools/harness/check-non-production-score-path.js",
    "harness:check:replay-exit-audio": "node tools/harness/check-replay-exit-wait-audio.js",
    "harness:check:board-messages": "node tools/harness/check-board-messages.js",
    "harness:check:wait-score-overlay": "node tools/harness/check-wait-score-overlay.js",
    "harness:check:close-shot-hit": "node tools/harness/check-close-shot-hit.js",
    "harness": "node tools/harness/run-gameplay.js",
    "log-viewer": "node tools/log-viewer/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgwoods/Codex-Test1.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
