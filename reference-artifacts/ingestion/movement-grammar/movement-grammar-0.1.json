  "title": "Platinum Movement Grammar",
  "summary": "Define one reusable movement grammar for inferred target motion, authored runtime choreography, conformance scoring, and creative variation across Aurora, Galaxy Guardians, and future games.",
  "problem": "Movement conformance is currently split across Aurora challenge layouts, regular-stage entry helpers, dive logic, escort/capture code, Galaxy Guardians runtime rules, and ingestion analyzers. This makes single-stage tuning possible but makes source-derived variation and multi-game reuse unnecessarily hard.",
  "principles": [
    {
      "id": "one-grammar-many-surfaces",
      "label": "One grammar, many gameplay surfaces",
      "meaning": "Challenge stages, normal entries, dives, escorts, capture/rescue, and wrap/return should share a movement vocabulary even when their gameplay rules differ."
    },
    {
      "id": "reference-first-runtime-second",
      "label": "Reference first, runtime second",
      "meaning": "Ingested target video object tracks should become grammar candidates before runtime code is changed."
    },
    {
      "id": "conforming-and-creative-lanes",
      "label": "Conforming and creative lanes",
      "meaning": "The same grammar should support a strict reference-conformance lane and Aurora-owned production theme variations."
    },
    {
      "id": "compile-dont-copy",
      "label": "Compile, do not copy",
      "meaning": "Game packs should declare movement contracts. Runtime code should compile those contracts into actual positions, events, and animation phases."
    },
    {
      "id": "score-meaning-and-motion",
      "label": "Score meaning and motion",
      "meaning": "A pattern is successful only if object tracks, player meaning, safety, score opportunity, sprite phase, and event cues all line up."
    }
  ],
